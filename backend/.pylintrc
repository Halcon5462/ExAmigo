[MASTER]
load-plugins=pylint_django
django-settings-module=backend.settings
ignore-paths = .*[/\\]migrations[/\\].*
ignore=
    migrations,
    venv,
    .venv,
    node_modules,
    static,
    media

ignore-patterns=
    .*_pb2.py,
    .*generated.*,
    .*migrations.*


[MESSAGES CONTROL]
disable =
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    too-few-public-methods,
    too-many-return-statements,
    too-many-locals,
    no-member,
    abstract-method,
    invalid-str-returned,
    unused-argument,
    duplicate-code,
    import-error

[FORMAT]
max-line-length = 100

[TYPECHECK]
ignored-modules=cv2
